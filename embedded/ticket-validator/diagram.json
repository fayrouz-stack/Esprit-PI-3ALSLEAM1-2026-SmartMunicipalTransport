    { "type": "wokwi-resistor", "id": "rg", "top": 20, "left": 160, "attrs": { "value": "220" } },
    { "type": "wokwi-resistor", "id": "rr", "top": 60, "left": 160, "attrs": { "value": "220" } },
    { "type": "wokwi-pushbutton", "id": "btn1", "top": 140, "left": -60,
