    ["esp32:D26", "rr:1", "orange", []],
    ["rr:2", "ledRed:A", "red", []],
    ["ledRed:C", "esp32:GND.3", "black", []],
    ["btn1:1.l", "esp32:D32", "purple", []],
    ["btn1:2.l", "esp32:GND.4", "black", []],
    ["btn2:1.l", "esp32:D33", "purple", []],
    ["btn2:2.l", "esp32:GND.5", "black", []]
